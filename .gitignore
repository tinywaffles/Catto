jobs.json

# Claude / AI / MCP
.claude
.mcp.json
.mise.local.toml
.codex-tmp/
prototype/

# Python UV lock file (regenerated from pyproject.toml)
uv.lock

# Electron build output and compiled runtime binaries
electron/dist/
electron/out/
*.exe
*.dll
*.pak
*.dat
locales/
snapshot_blob.bin
v8_context_snapshot.bin
vk_swiftshader.dll
vulkan-1.dll
