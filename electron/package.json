{
  "name": "catto-desktop",
  "version": "8.0.0",
  "description": "Catto — OSINT Intelligence Dashboard (Desktop)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "electron:start": "electron .",
    "electron:build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.catto.desktop",
    "productName": "Catto",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Catto"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ]
  }
}
